PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/hattah

# Required for admin auth security.
ADMIN_PASSWORD=ChangeThisToAStrongPassword
ADMIN_JWT_SECRET=ChangeThisToAVeryLongRandomSecret

# Application URL used in email links
APP_BASE_URL=http://localhost:5000

# Outgoing order confirmation email identity
ORDER_FROM_NAME=HATTAH
ORDER_FROM_EMAIL=no-reply@yourdomain.com

# SMTP email transport for production order confirmation emails
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
